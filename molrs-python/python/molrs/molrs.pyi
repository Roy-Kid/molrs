        sampling: Optional[str] = None,
        domain: Optional[str] = None,
        target: Optional[str] = None,
    ) -> None: ...
    @property
    def name(self) -> str: ...
    @property
    def data(self) -> npt.NDArray | list[str] | str: ...
    @property
    def kind(self) -> str: ...

class VectorObservable:
    def __init__(
        self,
