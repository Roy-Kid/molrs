"""Type stubs for molrs Python bindings.

Hand-maintained. Keep in sync with the PyO3 source in `molrs-python/src/**.rs`
on every PR that touches `#[pyfunction]` or `#[pyclass]`. The docs CI runs a
freshness guard that asserts every export in `src/lib.rs` is declared here.
"""

from typing import Optional, Sequence
import numpy as np
import numpy.typing as npt

# Type aliases — `F = f64` is invariant in molrs-core; Python side must match.
ArrayF = npt.NDArray[np.float64]
ArrayBool = npt.NDArray[np.bool_]
ArrayU8 = npt.NDArray[np.uint8]
ArrayU32 = npt.NDArray[np.uint32]
ArrayI64 = npt.NDArray[np.int64]

# ---------------------------------------------------------------------------
# Simulation box
# ---------------------------------------------------------------------------

class Box:
    """Simulation box with periodic boundary conditions."""

    def __init__(
        self,
        h: ArrayF,
        origin: Optional[ArrayF] = None,
        pbc: Optional[ArrayBool] = None,
    ) -> None: ...
    @staticmethod
    def cube(
        a: float,
        origin: Optional[ArrayF] = None,
        pbc: Optional[ArrayBool] = None,
    ) -> Box: ...
    @staticmethod
    def ortho(
        lengths: ArrayF,
        origin: Optional[ArrayF] = None,
        pbc: Optional[ArrayBool] = None,
    ) -> Box: ...
    def volume(self) -> float: ...
    def lattice(self, index: int) -> ArrayF: ...
    @property
    def h(self) -> ArrayF: ...
    @property
    def origin(self) -> ArrayF: ...
    @property
    def pbc(self) -> ArrayBool: ...
    def lengths(self) -> ArrayF: ...
    def to_frac(self, xyz: ArrayF) -> ArrayF: ...
    def to_cart(self, xyzs: ArrayF) -> ArrayF: ...
    def wrap(self, xyzu: ArrayF) -> ArrayF: ...
    def delta(
        self, xyzu1: ArrayF, xyzu2: ArrayF, minimum_image: bool = False
    ) -> ArrayF: ...
    def isin(self, xyz: ArrayF) -> ArrayBool: ...

# ---------------------------------------------------------------------------
# Neighbor search
# ---------------------------------------------------------------------------

class NeighborList:
    """Result of a neighbor query — pairs within cutoff."""

    @property
    def query_point_indices(self) -> ArrayU32: ...
    @property
    def point_indices(self) -> ArrayU32: ...
    @property
    def distances(self) -> ArrayF: ...
    @property
    def dist_sq(self) -> ArrayF: ...
    @property
    def n_pairs(self) -> int: ...
    @property
    def num_points(self) -> int: ...
    @property
    def num_query_points(self) -> int: ...
    @property
    def is_self_query(self) -> bool: ...
    def pairs(self) -> ArrayI64: ...

class NeighborQuery:
    """Spatial neighbor query (freud-style)."""

    def __init__(self, box: Box, points: ArrayF, cutoff: float) -> None: ...
    def query(self, query_points: ArrayF) -> NeighborList: ...
    def query_self(self) -> NeighborList: ...

class LinkedCell:
    """Linked-cell neighbor list (legacy API; prefer NeighborQuery)."""

    def __init__(self, points: ArrayF, cutoff: float, box: Box) -> None: ...
    def pairs(self) -> ArrayI64: ...
    def update(self, points: ArrayF, box: Box) -> None: ...

# ---------------------------------------------------------------------------
# Block / Frame / Grid
# ---------------------------------------------------------------------------

class Block:
    """Heterogeneous column store (dict of typed numpy arrays)."""

    def __init__(self) -> None: ...
    def insert(self, key: str, array: npt.NDArray | Sequence[str]) -> None: ...
    def view(self, key: str) -> npt.NDArray | list[str]: ...
    @property
    def nrows(self) -> Optional[int]: ...
    def __len__(self) -> int: ...
    def keys(self) -> list[str]: ...
    def __contains__(self, key: str) -> bool: ...
    def remove(self, key: str) -> None: ...
    def dtype(self, key: str) -> str: ...

class Grid:
    """Uniform spatial grid storing multiple named scalar arrays."""

    def __init__(
        self,
        dim: Sequence[int],
        origin: ArrayF,
        cell: ArrayF,
        pbc: Sequence[bool],
    ) -> None: ...
    @property
    def dim(self) -> npt.NDArray[np.uintp]: ...
    @property
    def origin(self) -> ArrayF: ...
    @property
    def cell(self) -> ArrayF: ...
    @property
    def pbc(self) -> ArrayBool: ...
    @property
    def grid(self) -> ArrayF: ...
    def __getitem__(self, name: str) -> npt.NDArray: ...
    def __setitem__(self, name: str, data: ArrayF) -> None: ...
    def __contains__(self, name: str) -> bool: ...
    def __len__(self) -> int: ...
    def keys(self) -> list[str]: ...

class Frame:
    """Dictionary of Blocks (and optional Grids) with optional Box and metadata."""

    def __init__(self) -> None: ...
    def __getitem__(self, key: str) -> Block | Grid: ...
    def __setitem__(self, key: str, value: Block | Grid) -> None: ...
    def __delitem__(self, key: str) -> None: ...
    def __contains__(self, key: str) -> bool: ...
    def __len__(self) -> int: ...
    def keys(self) -> list[str]: ...
    def grids(self) -> dict[str, Grid]: ...
    @property
    def simbox(self) -> Optional[Box]: ...
    @simbox.setter
    def simbox(self, value: Optional[Box]) -> None: ...
    @property
    def meta(self) -> dict[str, str]: ...
    @meta.setter
    def meta(self, value: dict[str, str]) -> None: ...
    def validate(self) -> None: ...

# ---------------------------------------------------------------------------
# Regions (boolean compositions of primitive shapes)
# ---------------------------------------------------------------------------

class Sphere:
    """Solid sphere region."""

    def __init__(self, center: ArrayF, radius: float) -> None: ...
    def contains(self, points: ArrayF) -> ArrayBool: ...
    def bounds(self) -> ArrayF: ...
    def __and__(self, other: Sphere | HollowSphere | Region) -> Region: ...
    def __or__(self, other: Sphere | HollowSphere | Region) -> Region: ...
    def __invert__(self) -> Region: ...

class HollowSphere:
    """Hollow sphere (spherical shell) region."""

    def __init__(
        self, center: ArrayF, inner_radius: float, outer_radius: float
    ) -> None: ...
    def contains(self, points: ArrayF) -> ArrayBool: ...
    def bounds(self) -> ArrayF: ...
    def __and__(self, other: Sphere | HollowSphere | Region) -> Region: ...
    def __or__(self, other: Sphere | HollowSphere | Region) -> Region: ...
    def __invert__(self) -> Region: ...

class Region:
    """Composed geometric region (result of &, |, ~ operators)."""

    def contains(self, points: ArrayF) -> ArrayBool: ...
    def bounds(self) -> ArrayF: ...
    def __and__(self, other: Sphere | HollowSphere | Region) -> Region: ...
    def __or__(self, other: Sphere | HollowSphere | Region) -> Region: ...
    def __invert__(self) -> Region: ...

